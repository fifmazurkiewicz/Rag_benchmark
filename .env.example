# =============================================================================
# RAG Benchmark — environment variables
# Copy to .env and fill in your values.
# =============================================================================

# --- Required ----------------------------------------------------------------

# OpenRouter — single key for ALL LLM, embedding, and reranking calls.
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...


# --- Database passwords (match docker-compose.yml) ---------------------------

NEO4J_PASSWORD=password


# --- Optional: override individual providers ---------------------------------

# Direct OpenAI (only if not routing through OpenRouter)
# OPENAI_API_KEY=sk-...

# Direct Anthropic (only if not routing through OpenRouter)
# ANTHROPIC_API_KEY=sk-ant-...

# Direct Cohere (only if using cohere reranker without OpenRouter)
# COHERE_API_KEY=...
